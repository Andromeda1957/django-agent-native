#!/bin/bash
# Pre-commit quality gate: blocks the commit if lint, architecture contracts, or
# the security/memory checks fail. Fast checks only; the full test suite runs in
# CI so nothing broken reaches production.
#
# Enable once per clone:   git config core.hooksPath hooks
# Requires the dev tools on PATH — activate your venv first:
#   source .venv/bin/activate
set -e
cd "$(git rev-parse --show-toplevel)"

echo "pre-commit › ruff..."
ruff check .

echo "pre-commit › import-linter..."
lint-imports

echo "pre-commit › security-patterns..."
python3 tools/check_security_patterns.py

echo "pre-commit › memory-system..."
python3 tools/check_memory_system.py

echo "pre-commit › OK"
