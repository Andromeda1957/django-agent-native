# Copy this file to `.env` for local development. `.env` is git-ignored.
# In production, set these as real environment variables / secrets — never
# commit a real .env.

# Local development: turn DEBUG on. NEVER set True in production.
DEBUG=True

# Required when DEBUG=False. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
# SECRET_KEY=

# Comma-separated hostnames Django will serve (required when DEBUG=False).
# ALLOWED_HOSTS=example.com,www.example.com

# Database. Defaults to local SQLite if unset. Point at PostgreSQL in production:
# DATABASE_URL=postgres://user:password@127.0.0.1:5432/dbname
